// See https://go.microsoft.com/fwlink/?LinkId=733558
// for the documentation about the tasks.json format
{
	"version": "2.0.0",
	"tasks": [
		{
			"type": "npm",
			"script": "compile",
			"group": "build",
			"presentation": {
				"reveal": "silent"
			}
		},
		{
			"type": "npm",
			"script": "watch",
			"problemMatcher": {
				"pattern": {
					"regexp": ".*",
					"file": 1,
					"location": 2,
					"message": 3
				},
				"background": {
					"activeOnStart": true,
					"beginsPattern": "Starting compilation",
					"endsPattern": "(Watching for file changes|built in)"
				}
			},
			"isBackground": true,
			"presentation": {
				"reveal": "never"
			},
			"group": {
				"kind": "build",
				"isDefault": true
			},
			"dependsOn": "npm: compile"
		}
	]
}
