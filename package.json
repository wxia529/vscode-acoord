{
  "name": "acoord",
  "displayName": "ACoord",
  "description": "Atomic Coordinate Toolkit",
  "publisher": "wxia529",
  "version": "0.2.0",
  "license": "GPL-3.0-only",
  "icon": "media/acoord-icon.png",
  "keywords": [
    "chemistry",
    "materials",
    "crystal",
    "molecule",
    "structure",
    "visualization",
    "cif",
    "xyz",
    "vasp",
    "poscar",
    "xdatcar",
    "outcar"
  ],
  "homepage": "https://github.com/wxia529/vscode-acoord",
  "bugs": {
    "url": "https://github.com/wxia529/vscode-acoord/issues"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/wxia529/vscode-acoord"
  },
  "engines": {
    "vscode": "^1.109.0"
  },
  "main": "./out/extension.js",
  "activationEvents": [
    "onCustomEditor:acoord.structureEditor",
    "onCommand:acoord.openStructureEditor",
    "onCommand:acoord.createNewMolecule",
    "onCommand:acoord.createNewCrystal",
    "onLanguage:cif",
    "onLanguage:xyz"
  ],
  "contributes": {
    "customEditors": [
      {
        "viewType": "acoord.structureEditor",
        "displayName": "ACoord Structure Editor",
        "priority": "option",
        "selector": [
          {
            "filenamePattern": "*.cif"
          },
          {
            "filenamePattern": "*.xyz"
          },
          {
            "filenamePattern": "*.poscar"
          },
          {
            "filenamePattern": "*.vasp"
          },
          {
            "filenamePattern": "*POSCAR"
          },
          {
            "filenamePattern": "*CONTCAR"
          },
          {
            "filenamePattern": "*.xdatcar"
          },
          {
            "filenamePattern": "*XDATCAR"
          },
          {
            "filenamePattern": "*.outcar"
          },
          {
            "filenamePattern": "*OUTCAR"
          },
          {
            "filenamePattern": "*.pdb"
          },
          {
            "filenamePattern": "*.gjf"
          },
          {
            "filenamePattern": "*.com"
          },
          {
            "filenamePattern": "*.inp"
          },
          {
            "filenamePattern": "*.in"
          },
          {
            "filenamePattern": "*.pwi"
          },
          {
            "filenamePattern": "*.out"
          },
          {
            "filenamePattern": "*.pwo"
          },
          {
            "filenamePattern": "*.log"
          },
          {
            "filenamePattern": "*.stru"
          }
        ]
      }
    ],
    "menus": {
      "editor/title": [
        {
          "command": "acoord.openStructureEditor",
          "when": "resourceExtname =~ /\\.(cif|xyz|poscar|vasp|xdatcar|outcar|pdb|gjf|com|inp|in|pwi|out|pwo|log|stru)$/i || resourceFilename =~ /^(POSCAR|CONTCAR|XDATCAR|OUTCAR|STRU)$/i || editorLangId == gaussian",
          "group": "navigation"
        }
      ]
    },
    "views": {
      "explorer": [
        {
          "id": "acoordExplorer",
          "name": "ACoord Explorer",
          "when": "acoord.structureOpen",
          "icon": "media/preview-light.svg"
        }
      ]
    },
    "commands": [
      {
        "command": "acoord.createNewMolecule",
        "title": "ACoord: Create New Molecule",
        "category": "ACoord"
      },
      {
        "command": "acoord.createNewCrystal",
        "title": "ACoord: Create New Crystal",
        "category": "ACoord"
      },
      {
        "command": "acoord.openStructureEditor",
        "title": "ACoord: Open Structure Editor",
        "icon": {
          "light": "media/preview-light.svg",
          "dark": "media/preview-dark.svg"
        },
        "category": "ACoord"
      },
      {
        "command": "acoord.exportStructure",
        "title": "ACoord: Export Structure",
        "category": "ACoord"
      },
      {
        "command": "acoord.addAtom",
        "title": "ACoord: Add Atom",
        "category": "ACoord"
      },
      {
        "command": "acoord.deleteAtom",
        "title": "ACoord: Delete Selected Atom",
        "category": "ACoord"
      },
      {
        "command": "acoord.selectDisplayConfig",
        "title": "ACoord: Select Display Configuration",
        "category": "ACoord"
      },
      {
        "command": "acoord.saveDisplayConfig",
        "title": "ACoord: Save Current Display Settings",
        "category": "ACoord"
      },
      {
        "command": "acoord.exportDisplayConfigs",
        "title": "ACoord: Export Display Configurations",
        "category": "ACoord"
      },
      {
        "command": "acoord.importDisplayConfigs",
        "title": "ACoord: Import Display Configurations",
        "category": "ACoord"
      },
      {
        "command": "acoord.deleteDisplayConfig",
        "title": "ACoord: Delete Display Configuration",
        "category": "ACoord"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./ && node build/webview.mjs",
    "watch": "concurrently \"tsc -watch -p ./\" \"node build/webview.mjs --watch\"",
    "watch:tsc": "tsc -watch -p ./",
    "watch:webview": "node build/webview.mjs --watch",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "dependencies": {
    "@github/copilot": "^0.0.421",
    "three": "^0.183.2"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "@types/three": "^0.183.1",
    "@types/vscode": "^1.109.0",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2",
    "concurrently": "^9.2.1",
    "esbuild": "^0.27.3",
    "eslint": "^9.39.2",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.54.0"
  }
}
